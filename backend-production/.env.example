# Database Configuration
DATABASE_URL=postgresql://postgres:YOUR_REAL_PASSWORD@db.wdjgdvaiezjiuxysimnd.supabase.co:5432/postgres
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Server Configuration
NODE_ENV=production
PORT=4000
API_VERSION=v1

# Security
JWT_SECRET=your-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# CORS - Update with your frontend domains
CORS_ORIGIN=https://your-vercel-domain.vercel.app
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Service (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=Finance Monitor <noreply@yourdomain.com>

# Monitoring (Optional - Add when ready)
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

# Frontend URL (for email links, etc.)
FRONTEND_URL=https://your-vercel-domain.vercel.app

# Session
SESSION_SECRET=another-long-random-secret-at-least-32-characters
